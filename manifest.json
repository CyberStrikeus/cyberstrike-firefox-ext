{
  "manifest_version": 2,
  "name": "CyberStrike",
  "version": "1.1.0",
  "description": "Capture browser HTTP requests and forward them to CyberStrike server",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "cookies",
    "contextualIdentities"
  ],
  "background": {
    "scripts": ["background/background.js"]
  },
  "browser_action": {
    "default_title": "CyberStrike",
    "default_popup": "popup/popup.html"
  }
}
